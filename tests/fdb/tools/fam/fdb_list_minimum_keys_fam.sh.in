#!/usr/bin/env bash

set -euxo pipefail

yell() { printf "$(basename "$0"): \033[0;31m!!! %s !!!\033[0m\\n" "$*" >&2; }
die() { yell "$*"; exit 1; }
try() { "$@" || die "Errored HERE => '$*'"; }

line_count() {
  [[ $# -eq 1 ]] || die "line_count requires 1 argument; expected line count"
  val=$(wc -l < out) && val=$((val + 0))
  [[ $val -eq $1 ]] || die "Incorrect count => [$val != $1]"
}

########################################################################################################################

export PATH=@CMAKE_BINARY_DIR@/bin:$PATH
export FDB_HOME=@PROJECT_BINARY_DIR@

test_name=fam_minimum_keys
src_data="../../../od.oper.grib"
src_dir=@CMAKE_CURRENT_SOURCE_DIR@
bin_dir=@CMAKE_CURRENT_BINARY_DIR@

# When ECKIT_FAM_TEST_ENDPOINT is set (real OpenFAM), use it verbatim.
# Otherwise (mock), embed PID in hostname so each test gets its own shm segment.
fam_endpoint="${ECKIT_FAM_TEST_ENDPOINT:-localhost_$$:8880}"
test_region="fdb_list_fam_min_keys_$$"
fam_uri="fam://${fam_endpoint}/${test_region}"

########################################################################################################################

echo "running test '$test_name' on $(hostname)"

try cd $bin_dir

try rm -rf $test_name
try mkdir -p $test_name/localroot

try cd $test_name

# Repack source data to a tiny grid to reduce FAM memory footprint (76 MB → ~3 KB)
try grib_set -s packingType=grid_simple,gridType=regular_ll,Ni=10,Nj=10,iDirectionIncrementInDegrees=36,jDirectionIncrementInDegrees=18,bitsPerValue=8 "$src_data" od.oper.small.grib
src_data="od.oper.small.grib"

# Create the FAM region (4 MB — repacked data is ~3 KB, 1 write)
try fdb-fam --endpoint="$fam_endpoint" --create --size=33554432 --perm=0640 "/$test_region"

cleanup() {
    echo "cleanup"
    fdb-fam --endpoint="$fam_endpoint" --delete "/$test_region" 2>/dev/null || true
    rm -rf "$bin_dir/$test_name" 2>/dev/null || true
    # Remove per-process mock shm segment (no-op when using real OpenFAM)
    [[ -z "${ECKIT_FAM_TEST_ENDPOINT:-}" ]] && rm -f "/dev/shm/eckit_fam_mock_localhost_$$" 2>/dev/null || true
}
trap cleanup EXIT

schema_src="$FDB_HOME/etc/fdb/schema"

cat > local.yaml <<EOF
---
type: local
engine: fam
schema: ${schema_src}
store: fam
catalogue: fam
spaces:
- handler: Default
  roots:
  - path: $(pwd)/localroot
fam_roots:
- uri: ${fam_uri}
  writable: true
  visit: true
EOF

export FDB5_CONFIG_FILE="$(pwd)/local.yaml"

work_dir=$(pwd)
echo "Working directory: $work_dir"

########################################################################################################################

# Ensure that we can wipe specified databases, but only when fully specified

try grib_set -s class=rd,expver=xxxx "$src_data" data.xxxx.grib
try grib_ls -m data.xxxx.grib
try fdb-write data.xxxx.grib


echo "Test: check all output"
try fdb-list --all --full --minimum-keys= --porcelain | tee out
line_count 24


echo "Test: nothing happens if any of the keys are missing"
set +e
for invalid_key in class=rd expver=xxxx; do
  fdb-list $invalid_key
  rc=$?
  [[ $rc = 0 ]] && die "Should not have succeeded: $invalid_key"
done
set -e


echo "Test: supplying the key"
try fdb-list class=rd,expver=xxxx --porcelain | tee out
line_count 24


echo "Test: changing the minimum keys"
set +e
for invalid_key in class=rd,expver=xxxx class=rd,time=1200 expver=xxxx,time=1200; do
  fdb-list --minimum-keys="class,expver,time" $invalid_key
  rc=$?
  [[ $rc = 0 ]] && die "Should not have succeeded: $invalid_key"
done
set -e


echo "Test: the purge works now this is supplied"
try fdb-list --minimum-keys="class,expver,time" class=rd,expver=xxxx,time=1200 --porcelain | tee out
line_count 12
